#task 13c
questions = [
    "capital of france?",
    "5+3=?",
    "colour of the sky?"
]

answers = ["paris", "8", "blue"]

score = 0

for i in range(len(questions)):
    user = input(questions[i] + " ")
    user = user.lower()

    if user == answers[i]:
        score += 1

print("your score is", score)